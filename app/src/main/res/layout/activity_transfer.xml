<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ws_bg">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="32dp"
            android:paddingBottom="24dp">

            <!-- ── Icon circle ── -->
            <FrameLayout
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:layout_gravity="center_horizontal">
                <View android:layout_width="96dp" android:layout_height="96dp"
                    android:background="@drawable/bg_icon_circle"/>
                <TextView
                    android:id="@+id/tvIcon"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="📤"
                    android:textSize="44sp"
                    android:gravity="center"/>
            </FrameLayout>

            <!-- Status + file counter -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="16dp">

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SENDING"
                    android:textColor="@color/ws_on_surface_dim"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvFileCounter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1 / 3"
                    android:textColor="@color/ws_primary"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_pill_accent"
                    android:visibility="gone"/>
            </LinearLayout>

            <!-- File name -->
            <TextView
                android:id="@+id/tvFileName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="@color/ws_on_surface"
                android:textSize="17sp"
                android:textStyle="bold"
                android:gravity="center"
                android:maxLines="2"
                android:ellipsize="middle"
                android:layout_marginTop="10dp"/>

            <!-- ── Speed display ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginTop="28dp">

                <TextView
                    android:id="@+id/tvSpeed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 KB/s"
                    android:textColor="@color/ws_primary"
                    android:textSize="48sp"
                    android:textStyle="bold"
                    android:letterSpacing="-0.02"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="6dp">

                    <TextView
                        android:id="@+id/tvPercent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textColor="@color/ws_on_surface_dim"
                        android:textSize="14sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="  ·  "
                        android:textColor="@color/ws_on_surface_faint"
                        android:textSize="14sp"/>

                    <TextView
                        android:id="@+id/tvEta"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="@color/ws_on_surface_dim"
                        android:textSize="14sp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- ── Progress bar ── -->
            <ProgressBar
                android:id="@+id/progressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="14dp"
                android:max="100"
                android:progressDrawable="@drawable/bg_progress_track"
                android:layout_marginTop="24dp"/>

            <!-- Bytes row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">
                <TextView
                    android:id="@+id/tvBytesSent"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="0 B sent"
                    android:textColor="@color/ws_on_surface_faint"
                    android:textSize="12sp"/>
                <TextView
                    android:id="@+id/tvTotalSize"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="of 0 B"
                    android:textColor="@color/ws_on_surface_faint"
                    android:textSize="12sp"/>
            </LinearLayout>

            <!-- ── Speed bars visualizer ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:gravity="bottom|center_horizontal"
                android:layout_marginTop="20dp">

                <View android:id="@+id/bar1" android:layout_width="0dp" android:layout_height="match_parent"
                    android:layout_weight="1" android:background="@color/ws_primary" android:layout_marginEnd="3dp"
                    android:scaleY="0.1" android:transformPivotY="100dp"/>
                <View android:id="@+id/bar2" android:layout_width="0dp" android:layout_height="match_parent"
                    android:layout_weight="1" android:background="@color/ws_primary" android:layout_marginEnd="3dp"
                    android:scaleY="0.1" android:transformPivotY="100dp"/>
                <View android:id="@+id/bar3" android:layout_width="0dp" android:layout_height="match_parent"
                    android:layout_weight="1" android:background="@color/ws_primary_container" android:layout_marginEnd="3dp"
                    android:scaleY="0.1" android:transformPivotY="100dp"/>
                <View android:id="@+id/bar4" android:layout_width="0dp" android:layout_height="match_parent"
                    android:layout_weight="1" android:background="@color/ws_primary_container" android:layout_marginEnd="3dp"
                    android:scaleY="0.1" android:transformPivotY="100dp"/>
                <View android:id="@+id/bar5" android:layout_width="0dp" android:layout_height="match_parent"
                    android:layout_weight="1" android:background="@color/ws_accent_container" android:layout_marginEnd="3dp"
                    android:scaleY="0.1" android:transformPivotY="100dp"/>
                <View android:id="@+id/bar6" android:layout_width="0dp" android:layout_height="match_parent"
                    android:layout_weight="1" android:background="@color/ws_accent_container" android:layout_marginEnd="3dp"
                    android:scaleY="0.1" android:transformPivotY="100dp"/>
                <View android:id="@+id/bar7" android:layout_width="0dp" android:layout_height="match_parent"
                    android:layout_weight="1" android:background="@color/ws_accent"
                    android:scaleY="0.1" android:transformPivotY="100dp"/>
            </LinearLayout>

            <!-- Summary card (visible on done) -->
            <LinearLayout
                android:id="@+id/cardSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="18dp"
                android:layout_marginTop="20dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvSummaryTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Transfer complete"
                    android:textColor="@color/ws_on_surface"
                    android:textSize="15sp"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/tvSummaryDetail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/ws_on_surface_dim"
                    android:textSize="13sp"
                    android:layout_marginTop="4dp"/>
                <TextView
                    android:id="@+id/tvSummarySpeed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/ws_primary"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/ws_divider"
                android:layout_marginTop="28dp" android:layout_marginBottom="20dp"/>

            <!-- Action buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnPauseResume"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/bg_button_secondary"
                    android:text="⏸  Pause"
                    android:textColor="@color/ws_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:stateListAnimator="@null"/>

                <Button
                    android:id="@+id/btnAction"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_button_danger"
                    android:text="Cancel"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:stateListAnimator="@null"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Floating error bar -->
    <LinearLayout
        android:id="@+id/layoutError"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#EE1A1A2A"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:visibility="gone">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="⚠" android:textColor="#FFCC00"
            android:textSize="18sp" android:layout_marginEnd="12dp"/>
        <TextView
            android:id="@+id/tvErrorMsg"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=""
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:maxLines="2"
            android:ellipsize="end"/>
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
