<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_device_item"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="14dp"
    android:layout_marginBottom="8dp">

    <TextView
        android:id="@+id/tvHistIcon"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:text="📤"
        android:textSize="22sp"
        android:gravity="center"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp">

        <TextView
            android:id="@+id/tvHistFileName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="filename.mp4"
            android:textColor="@color/ws_on_surface"
            android:textSize="14sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/tvHistSize"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0 B / 0 B"
                android:textColor="@color/ws_on_surface_dim"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/tvHistStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="done"
                android:textColor="#00C853"
                android:textSize="12sp"
                android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
