<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ws_bg"
    android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="16dp"
        android:background="@color/ws_surface">
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:id="@+id/tvScanTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Find a Device"
                android:textColor="@color/ws_on_surface"
                android:textSize="20sp"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/tvThisDeviceName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/ws_on_surface_faint"
                android:textSize="11sp"
                android:layout_marginTop="2dp"
                android:maxLines="1"
                android:ellipsize="end"/>
        </LinearLayout>
        <Button
            android:id="@+id/btnRefresh"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:background="@drawable/bg_button_secondary"
            android:text="Refresh"
            android:textColor="@color/ws_primary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:stateListAnimator="@null"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/ws_stroke" android:alpha="0.5"/>

    <!-- Radar zone -->
    <FrameLayout
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="4dp">

        <View android:id="@+id/radarRing3"
            android:layout_width="200dp" android:layout_height="200dp"
            android:background="@drawable/bg_radar" android:alpha="0.2"/>
        <View android:id="@+id/radarRing2"
            android:layout_width="144dp" android:layout_height="144dp"
            android:background="@drawable/bg_radar"
            android:layout_gravity="center" android:alpha="0.4"/>
        <View android:id="@+id/radarRing1"
            android:layout_width="88dp" android:layout_height="88dp"
            android:background="@drawable/bg_radar"
            android:layout_gravity="center" android:alpha="0.7"/>

        <FrameLayout
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center">
            <View android:layout_width="56dp" android:layout_height="56dp"
                android:background="@drawable/bg_icon_circle"/>
            <TextView
                android:id="@+id/tvRadarIcon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="📡"
                android:textSize="28sp"
                android:gravity="center"/>
        </FrameLayout>
    </FrameLayout>

    <TextView
        android:id="@+id/tvScanStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text="Scanning for nearby devices…"
        android:textColor="@color/ws_on_surface_dim"
        android:textSize="13sp"
        android:layout_marginBottom="16dp"/>

    <!-- Section label -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="NEARBY DEVICES"
        android:textColor="@color/ws_on_surface_faint"
        android:textSize="10sp"
        android:letterSpacing="0.14"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:layout_marginBottom="4dp"/>

    <!-- Device list (SEND mode) -->
    <ListView
        android:id="@+id/lvDevices"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@null"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:clipToPadding="false"
        android:layoutAnimation="@anim/list_layout_anim"/>

    <!-- Waiting card (RECEIVE mode) -->
    <LinearLayout
        android:id="@+id/receiveWaitCard"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone">

        <FrameLayout
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="24dp">
            <View android:layout_width="96dp" android:layout_height="96dp"
                android:background="@drawable/bg_icon_circle"/>
            <TextView android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="📲" android:textSize="48sp" android:gravity="center"/>
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="You're Visible"
            android:textColor="@color/ws_on_surface"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Open WillyShare on the sender's device, tap Send, and select your device from their list."
            android:textColor="@color/ws_on_surface_dim"
            android:textSize="14sp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.5"/>

        <!-- Animated dots -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:orientation="horizontal"
            android:layout_marginTop="28dp">
            <View android:layout_width="8dp" android:layout_height="8dp"
                android:background="@drawable/bg_radar" android:layout_marginEnd="8dp"/>
            <View android:layout_width="8dp" android:layout_height="8dp"
                android:background="@drawable/bg_radar" android:layout_marginEnd="8dp" android:alpha="0.6"/>
            <View android:layout_width="8dp" android:layout_height="8dp"
                android:background="@drawable/bg_radar" android:alpha="0.3"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
