<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
        <shape android:shape="rectangle">
            <solid android:color="@color/ws_surface_container_high"/>
            <corners android:radius="10dp"/>
        </shape>
    </item>
    <item android:id="@android:id/progress">
        <clip>
            <shape android:shape="rectangle">
                <gradient
                    android:startColor="@color/ws_primary"
                    android:centerColor="@color/ws_primary_container"
                    android:endColor="@color/ws_accent_container"
                    android:angle="0"/>
                <corners android:radius="10dp"/>
            </shape>
        </clip>
    </item>
</layer-list>
